---
import BrandLayout from "../layouts/BrandLayout.astro";
import site from "../../data/site.json";

const title = `${site.mainKey} Ueber uns - unabhangiger Brand-Ratgeber`;
const description = `${site.mainKey} Ueber-uns-Seite: redaktionelle Regeln, Quellenhandling und unabhangige Informationshaltung des Brand-Templates.`;
---

<BrandLayout title={title} description={description} path="/ueber-uns/" commercial={false}>
  <section class="hero" slot="hero">
    <div class="hero-inner">
      <div>
        <p class="eyebrow">Editorial</p>
        <h1>Ueber uns</h1>
        <p class="lead">Dieses Projekt ist ein Template fur unabhangige Informationsseiten. Es ist keine offizielle Marken-, Casino-, Zahlungs- oder Regulatoren-Seite.</p>
      </div>
      <div class="hero-visual">
        <img src="/shared/brand-visual.svg" alt={`${site.mainKey} redaktioneller Brand-Ratgeber`} title={`${site.mainKey} Redaktion`} width="960" height="640" />
      </div>
    </div>
  </section>
  <section class="content">
    <h2>Redaktionelle Regeln</h2>
    <p>Wir trennen verifizierte Fakten, nutzerbereitgestellte Annahmen und unresolved Punkte. Ohne Quelle werden keine Lizenz-, Bonus-, Zahlungs-, Support- oder App-Store-Claims veroffentlicht.</p>
    <h2>Warum das wichtig ist</h2>
    <p>Brand-Keywords konnen leicht wie offizielle Navigation wirken. Dieses Template baut deshalb sichtbare Disclosures, sichere CTAs und Source-Gates in die Struktur ein.</p>
  </section>
</BrandLayout>
