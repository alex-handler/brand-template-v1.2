---
import BrandLayout from "../layouts/BrandLayout.astro";
import Hero from "../components/Hero.astro";
import FactTable from "../components/FactTable.astro";
import CtaBand from "../components/CtaBand.astro";
import SlotGrid from "../components/SlotGrid.astro";
import PaymentTiles from "../components/PaymentTiles.astro";
import site from "../../data/site.json";

const title = "Revolut Slots Deutschland - Casino, App, Bonus und Sportwetten";
const description = "Revolut Slots Ratgeber für Deutschland: Revolut casino, App, Bonus, Registrierung, Einzahlungen, Sportwetten und 42 Slot-Icons im sicheren Überblick.";
---

<BrandLayout title={title} description={description} path="/">
  <Hero slot="hero" title="Revolut Slots" lead="Revolut Slots ist hier als deutscher Brand-Ratgeber aufgebaut: kompakter Hero, klickbare Registrierung, Slot-Menü mit 200x200 Icons, App-, Bonus-, Einzahlungs- und Sportwetten-Unterseiten." />

  <section class="content">
    <div class="disclosure">{site.independentDisclosure} Revolut casino, Bonus, App, Lizenz, Zahlungen und Sportwetten bleiben quellenpflichtige Themen.</div>
    <h2>Revolut Slots als Brand-Template</h2>
    <p>Diese <a href="/">Revolut Slots Hauptseite</a> ist der zentrale Hub für alle kommerziellen Suchintentionen. Der Aufbau folgt GOAT: Ziel definieren, Quellen beobachten, Seiten erzeugen und erst nach Build, AMP- und Brand-Audit freigeben.</p>
    <p>Der zweite Fokus liegt auf Revolut casino. Dieser Begriff wird nicht als offizielles Produkt behauptet, sondern als Suchintention behandelt. Deshalb trennen alle Texte zwischen Ratgeber, möglichem Anbieterziel und ungeprüften Claims.</p>
    <p>Für spätere Markenwechsel bleiben Struktur, Prüfregeln und Komponenten gleich, aber Reihenfolge, Slot-Auswahl, Hero-Bild, Tabellenwerte und Textwinkel können aus den Daten neu gemischt werden. So entsteht nicht jedes Mal dieselbe Seite mit ausgetauschtem Namen.</p>

    <FactTable caption="Revolut Slots Schnellcheck" rows={[
      ["Main Key", "Revolut Slots"],
      ["Zweiter Key", "Revolut casino"],
      ["Geo", "Deutschland / de-DE"],
      ["Pflichtseiten", "App, Bonus, Registrierung, Einzahlungen, Sportwetten, Cookie, Privacy, Verantwortung"],
      ["Schema-Basis", "Organization, WebPage, Article, BreadcrumbList, ItemList"],
      ["Status", "Preview-fähige Informationsseite, keine offizielle Revolut Website"]
    ]} />

    <div class="grid">
      <div class="tile"><b>App</b><p>Mobile Nutzung, APK-Sicherheit, Browser-Alternative und Login-Fragen werden auf der <a href="/app/">App-Seite</a> getrennt erklärt.</p></div>
      <div class="tile"><b>Bonus</b><p>Promo Code, Freispiele und No-Deposit-Intent werden auf der <a href="/bonus/">Bonus-Seite</a> ohne erfundene Beträge behandelt.</p></div>
      <div class="tile"><b>Einzahlungen</b><p>Die <a href="/zahlungen/">Einzahlungsseite</a> nutzt die Payment-Entity-Regeln aus der Tabelle und bleibt bei operator-abhängigen Angaben vorsichtig.</p></div>
    </div>
  </section>

  <SlotGrid limit={42} heading="Revolut Slots Spielemenü" intro="Alle 42 aus dem DrückGlück-Quelltext extrahierten 200x200 Slot-Icons werden als quadratische Karten eingebunden." />
  <PaymentTiles />

  <section class="content">
    <h2>Warum die Slot-Icons lokal im Repository liegen</h2>
    <p>Die Icons wurden aus öffentlich erreichbaren `gameRes/sq/200`-URLs extrahiert und in `public/assets/slots/` gespeichert. So kann Cloudflare Pages sie direkt ausliefern, ohne dass die Seite auf fremde Bild-Hosts angewiesen ist.</p>
    <h2>Revolut casino und Brand-Safety</h2>
    <p>Brand-Seiten sind riskanter als reine Slot-Seiten. Diese Version vermeidet offizielle Markenbehauptungen, fake Auszahlungsversprechen und erfundene Lizenztexte. Mehr Details stehen in der <a href="/verantwortungsvolles-spielen/">Responsible-Gambling-Seite</a>.</p>
    <CtaBand text="kompakte Registrierung testen" />
  </section>
</BrandLayout>
