---
import BrandLayout from "../layouts/BrandLayout.astro";
import site from "../../data/site.json";

const title = `${site.mainKey} Cookies - Cookie-Hinweise`;
const description = `${site.mainKey} Cookie-Hinweise fur das Brand-Template, inklusive Platzhaltern fur spatere Analytics- oder Consent-Konfiguration.`;
---

<BrandLayout title={title} description={description} path="/cookies/" commercial={false}>
  <section class="hero" slot="hero">
    <div class="hero-inner">
      <div>
        <p class="eyebrow">Cookies</p>
        <h1>Cookies</h1>
        <p class="lead">Diese statische Vorlage setzt keine projektbezogenen Tracking-Cookies, bis sie explizit konfiguriert werden.</p>
      </div>
    </div>
  </section>
  <section class="content">
    <h2>Technische Cookies</h2>
    <p>Wenn spater Consent, Analytics oder A/B-Tests aktiviert werden, muss diese Seite angepasst werden.</p>
    <h2>Externe Anbieter</h2>
    <p>Externe Zielseiten konnen eigene Cookies setzen. Darauf hat diese Informationsseite keinen Einfluss.</p>
  </section>
</BrandLayout>
