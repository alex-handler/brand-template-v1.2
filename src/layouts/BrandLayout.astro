---
import site from "../../data/site.json";

const {
  title,
  description,
  path = "/",
  pageType = "Article",
  commercial = true
} = Astro.props;

const canonical = new URL(path, site.siteUrl).toString();
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${site.siteUrl}/#website`,
      "name": site.brandName,
      "url": site.siteUrl,
      "inLanguage": site.locale
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": title,
      "description": description,
      "isPartOf": { "@id": `${site.siteUrl}/#website` },
      "inLanguage": site.locale
    },
    {
      "@type": pageType,
      "@id": `${canonical}#article`,
      "headline": title,
      "description": description,
      "mainEntityOfPage": { "@id": `${canonical}#webpage` },
      "inLanguage": site.locale,
      "publisher": {
        "@type": "Organization",
        "name": `${site.brandName} informational guide`
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": site.mainKey,
          "item": site.siteUrl
        }
      ]
    }
  ]
};
---

<!doctype html>
<html lang={site.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={site.locale} href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <style is:global>
      :root{
        --ink:#112021;
        --muted:#526462;
        --line:#d9e8e3;
        --soft:#eff8f4;
        --brand:#0f6f60;
        --accent:#f2b43f;
        --alert:#d95040;
        --paper:#ffffff;
        --dark:#0f2e2d;
        --max:1120px;
      }
      *{box-sizing:border-box}
      body{margin:0;font-family:Inter,Arial,sans-serif;color:var(--ink);background:#fbfefd;line-height:1.6}
      a{color:inherit;text-decoration:none}
      img{max-width:100%;height:auto}
      .topbar{position:sticky;top:0;z-index:10;background:rgba(255,255,255,.96);border-bottom:1px solid var(--line);backdrop-filter:blur(14px)}
      .nav{max-width:var(--max);margin:0 auto;padding:12px 18px;display:flex;align-items:center;justify-content:space-between;gap:16px}
      .brandmark{display:flex;align-items:center;gap:10px;font-weight:900}
      .brandmark span:first-child{display:grid;place-items:center;width:38px;height:38px;border-radius:8px;background:var(--dark);color:#fff}
      .navlinks{display:flex;align-items:center;gap:12px;font-size:14px;color:var(--muted)}
      .navlinks a{padding:8px 4px}
      .top-cta,.button{display:inline-flex;align-items:center;justify-content:center;min-height:44px;padding:10px 16px;border-radius:8px;background:var(--brand);color:#fff;font-weight:800;border:1px solid var(--brand)}
      .hero{background:linear-gradient(130deg,#eff8f4 0%,#fff7dc 56%,#ffffff 100%);border-bottom:1px solid var(--line)}
      .hero-inner{max-width:var(--max);margin:0 auto;padding:62px 18px 44px;display:grid;grid-template-columns:minmax(0,1fr) minmax(300px,.82fr);gap:32px;align-items:center}
      .eyebrow{display:inline-flex;align-items:center;gap:8px;margin:0 0 14px;color:#0a5c50;font-weight:900;text-transform:uppercase;font-size:12px;letter-spacing:0}
      h1{margin:0;font-size:clamp(38px,6vw,66px);line-height:1.02;letter-spacing:0}
      h2{margin:42px 0 12px;font-size:clamp(26px,4vw,38px);line-height:1.12;letter-spacing:0}
      h3{margin:24px 0 8px;font-size:21px;line-height:1.25;letter-spacing:0}
      p{margin:0 0 16px}
      .lead{font-size:19px;color:#2f4744;max-width:720px}
      .hero-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:24px}
      .button.secondary{background:#fff;color:var(--dark);border-color:var(--line)}
      .hero-visual{border:1px solid var(--line);border-radius:8px;overflow:hidden;background:#fff;box-shadow:0 18px 45px rgba(15,46,45,.12)}
      .disclosure{max-width:var(--max);margin:0 auto;padding:12px 18px;color:#51625f;font-size:13px}
      .content{max-width:var(--max);margin:0 auto;padding:38px 18px}
      .band{background:var(--soft);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
      .grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px}
      .tile{background:#fff;border:1px solid var(--line);border-radius:8px;padding:18px}
      .tile strong{display:block;margin-bottom:8px}
      .fact-table{width:100%;border-collapse:collapse;margin:22px 0;background:#fff;border:1px solid var(--line);border-radius:8px;overflow:hidden}
      .fact-table caption{text-align:left;font-weight:900;padding:12px 14px;background:#123633;color:#fff}
      .fact-table th,.fact-table td{padding:13px 14px;border-top:1px solid var(--line);vertical-align:top;text-align:left}
      .fact-table th{width:34%;color:#173d3a;background:#f7fbf9}
      .note{border-left:5px solid var(--accent);background:#fff9e7;padding:16px 18px;border-radius:8px;margin:22px 0}
      .warning{border-left-color:var(--alert);background:#fff1ee}
      .cta-band{display:flex;align-items:center;justify-content:space-between;gap:18px;margin:28px 0;padding:20px;border-radius:8px;background:#102f2d;color:#fff}
      .cta-band p{margin:4px 0 0;color:#d6e9e3}
      .cta-band a{flex:0 0 auto;background:var(--accent);color:#13201d;padding:11px 16px;border-radius:8px;font-weight:900}
      .cta-band.compact{margin:16px 0}
      ul,ol{padding-left:22px}
      li{margin:7px 0}
      footer{border-top:1px solid var(--line);background:#0f2e2d;color:#d6e9e3}
      .footer-inner{max-width:var(--max);margin:0 auto;padding:28px 18px;display:grid;grid-template-columns:1fr auto;gap:22px}
      .footer-links{display:flex;flex-wrap:wrap;gap:12px}
      @media (max-width:780px){
        .hero-inner{grid-template-columns:1fr;padding-top:38px}
        .nav{align-items:flex-start}
        .navlinks{display:none}
        .grid{grid-template-columns:1fr}
        .cta-band{display:block}
        .cta-band a{margin-top:12px;width:100%}
        .footer-inner{grid-template-columns:1fr}
      }
    </style>
  </head>
  <body>
    <header class="topbar">
      <nav class="nav" aria-label="Main navigation">
        <a class="brandmark" href="/">
          <span>R</span>
          <span>{site.mainKey}</span>
        </a>
        <div class="navlinks">
          {site.navigation.map((item) => <a href={item.href}>{item.label}</a>)}
        </div>
        {commercial && <a class="top-cta" href={site.playPath} rel="nofollow">{site.copy.primaryCta}</a>}
      </nav>
    </header>
    <slot name="hero" />
    <p class="disclosure">{site.independentDisclosure}</p>
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-inner">
        <div>
          <strong>{site.mainKey}</strong>
          <p>{site.copy.riskNote} {site.copy.sourceNote}</p>
        </div>
        <div class="footer-links">
          <a href="/verantwortungsvolles-spielen/">Verantwortung</a>
          <a href="/ueber-uns/">Ueber uns</a>
          <a href="/datenschutz/">Datenschutz</a>
          <a href="/cookies/">Cookies</a>
        </div>
      </div>
    </footer>
  </body>
</html>
