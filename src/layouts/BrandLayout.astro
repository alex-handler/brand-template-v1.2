---
import site from "../../data/site.json";
import slots from "../../data/drueckglueck-slots.json";

const {
  title,
  description,
  path = "/",
  commercial = true,
  pageKind = "Article"
} = Astro.props;

const canonical = new URL(path, site.siteUrl).toString();
const nav = site.navigation;
const themeColor = site.visualStyle?.primaryColor || "#071d38";
const internalLinks = [
  { label: "Startseite", href: "/" },
  ...site.navigation.filter((item) => item.href !== "/"),
  { label: "Verantwortung", href: "/verantwortungsvolles-spielen/" },
  { label: "Datenschutz", href: "/datenschutz/" },
  { label: "Cookies", href: "/cookies/" }
];
const graph = [
  {
    "@type": "WebSite",
    "@id": `${site.siteUrl}/#website`,
    "name": site.mainKey,
    "url": site.siteUrl,
    "inLanguage": site.locale
  },
  {
    "@type": "Organization",
    "@id": `${site.siteUrl}/#organization`,
    "name": `${site.mainKey} unabhängiger Ratgeber`,
    "url": site.siteUrl,
    "address": { "@type": "PostalAddress", "addressCountry": site.geo },
    "areaServed": site.geo,
    "knowsAbout": ["Online Casino", "Slots", "Casino App", "Sportwetten", "Zahlungsmethoden"]
  },
  {
    "@type": "WebPage",
    "@id": `${canonical}#webpage`,
    "url": canonical,
    "name": title,
    "description": description,
    "isPartOf": { "@id": `${site.siteUrl}/#website` },
    "inLanguage": site.locale,
    "audience": { "@type": "Audience", "audienceType": "Erwachsene Nutzer in Deutschland" }
  },
  {
    "@type": pageKind,
    "@id": `${canonical}#article`,
    "headline": title,
    "description": description,
    "mainEntityOfPage": { "@id": `${canonical}#webpage` },
    "publisher": { "@id": `${site.siteUrl}/#organization` },
    "inLanguage": site.locale
  },
  {
    "@type": "BreadcrumbList",
    "@id": `${canonical}#breadcrumb`,
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": site.mainKey, "item": site.siteUrl },
      { "@type": "ListItem", "position": 2, "name": title, "item": canonical }
    ]
  }
];

if (commercial) {
  graph.push({
    "@type": "ItemList",
    "@id": `${canonical}#slots`,
    "name": `${site.mainKey} Slot-Auswahl`,
    "numberOfItems": slots.length,
    "itemListElement": slots.slice(0, 24).map((slot, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": slot.title,
      "url": new URL(slot.src, site.siteUrl).toString()
    }))
  });
}

const schema = { "@context": "https://schema.org", "@graph": graph };
---

<!doctype html>
<html amp lang={site.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,minimum-scale=1,initial-scale=1" />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    <meta name="msapplication-TileColor" content={themeColor} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={site.locale} href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColor} />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" as="image" href="/assets/hero/revolut-slots-hero-1600.webp" imagesrcset="/assets/hero/revolut-slots-hero-860.webp 860w, /assets/hero/revolut-slots-hero-1600.webp 1600w" imagesizes="100vw" fetchpriority="high" />
    <script async src="https://cdn.ampproject.org/v0.js"></script>
    <script async custom-element="amp-sidebar" src="https://cdn.ampproject.org/v0/amp-sidebar-0.1.js"></script>
    <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
    <style is:inline amp-boilerplate>body{-webkit-animation:-amp-start 8s steps(1,end) 0s 1 normal both;-moz-animation:-amp-start 8s steps(1,end) 0s 1 normal both;-ms-animation:-amp-start 8s steps(1,end) 0s 1 normal both;animation:-amp-start 8s steps(1,end) 0s 1 normal both}@-webkit-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@-moz-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@-ms-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@-o-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}</style><noscript><style is:inline amp-boilerplate>body{-webkit-animation:none;-moz-animation:none;-ms-animation:none;animation:none}</style></noscript>
    <style is:inline amp-custom>
      :root{--navy:#071d38;--navy2:#0b3157;--blue:#1467c9;--yellow:#ffd425;--cyan:#27f6ec;--paper:#fff;--ink:#081b2e;--muted:#657487;--line:#dbe7f2;--soft:#eef6ff;--max:1180px}
      *{box-sizing:border-box}html,body{margin:0;max-width:100%;overflow-x:hidden}body{font-family:Arial,Helvetica,sans-serif;color:var(--ink);background:#fff;line-height:1.55;padding-bottom:74px}a{text-decoration:none;color:inherit}button{font:inherit}ul,ol{list-style:none}
      .sticky-shell{position:sticky;top:0;z-index:40;background:#fff;box-shadow:0 14px 30px rgba(7,29,56,.14),0 2px 0 rgba(255,212,37,.65)}.sticky-shell:after{content:"";display:block;height:3px;background:linear-gradient(90deg,var(--yellow),var(--cyan),var(--yellow));box-shadow:0 0 18px rgba(39,246,236,.55)}.agebar{background:var(--navy2);color:#fff;font-weight:900;font-size:14px}.agebar-in{max-width:var(--max);margin:0 auto;min-height:38px;padding:5px 18px;display:flex;align-items:center;justify-content:center;gap:10px;text-align:center}.agebar b{display:inline-flex;align-items:center;justify-content:center;width:30px;height:30px;border:3px solid #e10b28;border-radius:50%;background:#fff;color:#111;flex:0 0 auto}
      .top{background:#fff;border-bottom:1px solid rgba(7,29,56,.08)}.nav{max-width:var(--max);margin:0 auto;display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:22px;padding:14px 18px}.logo{display:flex;align-items:center;gap:10px;font-weight:950;color:var(--navy);font-size:26px;min-width:0}.logo-flag{display:block;width:46px;height:46px;border-radius:50%;background:linear-gradient(to bottom,#111 0 33%,#dd0000 33% 66%,#ffce00 66%);box-shadow:0 0 0 3px #fff,0 0 0 4px var(--line);flex:0 0 auto}.logo-text{white-space:nowrap}.links{display:flex;gap:24px;justify-content:center;font-weight:850}.links a{padding:8px 2px}.actions{display:flex;gap:10px}.btn{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;padding:12px 20px;font-weight:950;border:0;min-height:44px}.btn-primary{background:var(--yellow);color:var(--navy)}.btn-secondary{background:#dceefa;color:var(--navy)}.burger{display:none;border:0;background:transparent;font-size:34px;line-height:1;color:var(--navy);justify-self:end}
      amp-sidebar{background:#fff;width:285px;padding:18px}.side-close{border:0;background:var(--navy);color:#fff;border-radius:8px;padding:9px 12px;font-weight:900}.side-nav{display:grid;gap:10px;margin-top:18px}.side-nav a{padding:13px;border-radius:8px;background:var(--soft);font-weight:900}.side-note{margin-top:18px;color:var(--muted);font-size:13px}
      .hero{position:relative;min-height:520px;background:var(--navy);color:#fff;overflow:hidden}.hero-bg{position:absolute;inset:0;z-index:0}.hero:before{content:"";position:absolute;inset:0;z-index:1;background:linear-gradient(90deg,rgba(6,20,48,.94),rgba(8,25,58,.76),rgba(8,25,58,.25))}.hero-in,.hero-inner,.terms{position:relative;z-index:2}.hero-in{max-width:var(--max);margin:0 auto;padding:54px 18px 38px;display:grid;grid-template-columns:minmax(0,.96fr) minmax(310px,.52fr);gap:24px;align-items:end}.hero-inner{max-width:var(--max);margin:0 auto;padding:54px 18px 38px}.eyebrow{display:inline-flex;align-items:center;color:var(--yellow);font-weight:950;text-transform:uppercase;font-size:13px;letter-spacing:0;margin:0 0 12px}h1{font-size:clamp(42px,7vw,82px);line-height:.98;letter-spacing:0;margin:0 0 16px}h2{font-size:clamp(26px,4vw,40px);line-height:1.1;margin:42px 0 14px;letter-spacing:0}h3{font-size:22px;line-height:1.2;margin:22px 0 9px;letter-spacing:0}.lead{font-size:20px;max-width:720px;margin:0 0 22px}.hero-card{background:rgba(7,29,56,.9);border:3px solid rgba(39,246,236,.8);border-radius:18px;padding:18px;box-shadow:0 18px 55px rgba(0,0,0,.28)}.hero-card strong{display:block;color:var(--yellow);font-size:24px;line-height:1.1;margin-bottom:8px}.hero-table{width:100%;border-collapse:collapse;color:#fff;font-size:14px}.hero-table th,.hero-table td{border-top:1px solid rgba(255,255,255,.18);padding:9px 0;text-align:left}.hero-table td{text-align:right;font-weight:850}.cta-row{display:flex;flex-wrap:wrap;gap:12px}.terms{background:var(--navy2);color:#fff;text-align:center;font-weight:850;padding:10px 14px}
      .content{max-width:var(--max);margin:0 auto;padding:34px 18px}.band{background:var(--soft);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}.disclosure{background:#fff8d7;border:1px solid #f3dc88;border-radius:8px;padding:14px 16px;margin:20px 0;color:#4b3a04}.grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px}.tile{background:#fff;border:1px solid var(--line);border-radius:8px;padding:18px;box-shadow:0 12px 28px rgba(9,49,87,.07)}.tile b{display:block;margin-bottom:8px;color:var(--navy)}.fact-table{width:100%;border-collapse:collapse;margin:22px 0;background:#fff;border:1px solid var(--line);border-radius:8px;overflow:hidden}.fact-table caption{text-align:left;background:var(--navy);color:#fff;font-weight:950;padding:12px 14px}.fact-table th,.fact-table td{padding:12px 14px;border-top:1px solid var(--line);text-align:left;vertical-align:top}.fact-table th{width:32%;background:#f7fbff;color:var(--navy)}
      .slot-head{display:flex;align-items:end;justify-content:space-between;gap:16px;margin-bottom:18px}.slot-head p{margin:0;color:var(--muted)}.slot-grid{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:14px}.slot-card{min-width:0}.slot-img{display:block;position:relative;border-radius:12px;overflow:hidden;background:#fff;border:1px solid var(--line);box-shadow:0 12px 30px rgba(7,29,56,.12);aspect-ratio:1/1;transition:transform .18s ease,box-shadow .18s ease}.slot-img:before{content:"";position:absolute;inset:0;background:rgba(7,29,56,.55);opacity:0;z-index:1;transition:opacity .18s ease}.slot-img:after{content:"";position:absolute;left:50%;top:50%;transform:translate(-42%,-50%) scale(.8);border-left:24px solid #fff;border-top:16px solid transparent;border-bottom:16px solid transparent;opacity:0;z-index:2;transition:opacity .18s ease,transform .18s ease}.slot-card:hover .slot-img,.slot-card:focus .slot-img{transform:translateY(-4px);box-shadow:0 18px 42px rgba(7,29,56,.22)}.slot-card:hover .slot-img:before,.slot-card:hover .slot-img:after,.slot-card:focus .slot-img:before,.slot-card:focus .slot-img:after{opacity:1}.slot-card:hover .slot-img:after,.slot-card:focus .slot-img:after{transform:translate(-42%,-50%) scale(1)}.slot-card b{display:block;margin-top:8px;font-size:14px;line-height:1.2;color:var(--navy);word-break:normal}.category-row{display:flex;flex-wrap:wrap;gap:10px;margin:14px 0 22px}.chip{border-radius:999px;background:#e1effa;color:var(--navy);padding:9px 14px;font-weight:900}
      .reverse-page>h2:first-of-type{margin-top:8px}.reverse-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;margin:22px 0}.info-card{background:linear-gradient(135deg,var(--navy),#104b78);border:0;border-left:6px solid var(--yellow);border-radius:0 8px 8px 0;padding:18px;color:#fff;box-shadow:0 16px 34px rgba(7,29,56,.16)}.note-panel,.reverse-block{background:#fff;border:1px solid var(--line);border-radius:8px;padding:18px;box-shadow:0 12px 28px rgba(9,49,87,.06)}.info-card b{color:#fff}.note-panel h3{color:var(--navy)}.info-card p{margin:8px 0 0;color:#dceafa}.split{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin:22px 0}.muted-panel{background:#f7fbff}.check-list,.number-list{margin:10px 0 0;padding:0;display:grid;gap:9px;list-style:none}.check-list li,.number-list li{position:relative;padding-left:24px;line-height:1.45}.check-list li:before{content:"";position:absolute;left:0;top:.62em;width:9px;height:9px;border-radius:50%;background:var(--blue)}.number-list{counter-reset:item}.number-list li{counter-increment:item}.number-list li:before{content:counter(item);position:absolute;left:0;top:.1em;width:17px;height:17px;border-radius:50%;background:var(--yellow);color:var(--navy);font-size:11px;font-weight:950;display:grid;place-items:center}.reverse-sections{display:grid;gap:18px}.reverse-block h2{margin-top:0}.reverse-block p:last-child{margin-bottom:0}.subsection{border-top:1px solid var(--line);margin-top:16px;padding-top:14px}.subsection h3{margin-top:0}.compact-list{grid-template-columns:repeat(2,minmax(0,1fr));gap:8px 14px}.depth-expansion{display:grid;gap:20px}.depth-block{border-top:4px solid var(--yellow);background:linear-gradient(180deg,#fff,#f8fbff);padding:20px 0 6px}.game-showcase{padding-top:42px}.game-section{border-top:1px solid var(--line);padding:20px 0}.game-title-row{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:14px;align-items:center;margin-bottom:14px;border-bottom:1px solid var(--line);padding-bottom:12px}.game-title-row h3{margin:0;color:var(--navy);font-size:28px}.game-title-row p{margin:4px 0 0;color:var(--muted)}.section-cta{display:inline-flex;align-items:center;justify-content:center;min-height:42px;padding:9px 18px;border-radius:999px;background:#e0eefb;color:var(--navy);font-weight:950}.mini-grid{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:14px}
      .pay-row{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}.pay-tile{background:#fff;border:1px solid var(--line);border-radius:8px;padding:18px;min-height:86px;display:grid;place-items:center;box-shadow:0 10px 24px rgba(7,29,56,.06)}.pay-logo{display:block;width:100%;height:54px;background-position:center;background-repeat:no-repeat;background-size:contain}.pay-logo.paypal{background-image:url('/assets/payments/paypal.svg')}.pay-logo.visa{background-image:url('/assets/payments/visa.svg')}.pay-logo.mastercard{background-image:url('/assets/payments/mastercard.svg')}.pay-logo.online{background-image:url('/assets/payments/online-uberweisen.svg')}.pay-logo.trustly{background-image:url('/assets/payments/trustly.svg')}.pay-logo.neteller{background-image:url('/assets/payments/neteller.svg')}.pay-logo.payz{background-image:url('/assets/payments/payz.svg')}
      .cta-band{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:14px;align-items:center;background:var(--navy);color:#fff;border-radius:10px;padding:20px;margin:26px 0}.cta-band p{margin:0;color:#d7e8fb}.cta-band .btn{white-space:nowrap}.internal-map{max-width:var(--max);margin:0 auto;padding:24px 18px;border-top:1px solid var(--line)}.internal-map strong{display:block;margin-bottom:12px;color:var(--navy);font-size:20px}.internal-links{display:flex;flex-wrap:wrap;gap:10px}.internal-links a{border:1px solid var(--line);border-radius:999px;padding:9px 14px;background:#fff;color:var(--navy);font-weight:850}.internal-links a:hover{border-color:var(--blue);box-shadow:0 8px 18px rgba(20,103,201,.14)}.service-list{display:flex;gap:18px;flex-wrap:wrap;justify-content:flex-end;align-items:center}.service-list a{color:#fff;border-bottom:1px solid rgba(255,255,255,.45);padding:3px 0;font-weight:850}.service-list a:hover{border-bottom-color:var(--yellow);color:var(--yellow)}footer{background:var(--navy);color:#dceafa}.foot{max-width:var(--max);margin:0 auto;padding:28px 18px;display:grid;grid-template-columns:1fr auto;gap:20px}.foot p{margin:6px 0 0;color:#bcd1e8}
      .sticky-cta{position:fixed;left:0;right:0;bottom:0;z-index:30;background:var(--navy);display:none;padding:10px 12px;gap:12px;align-items:center;box-shadow:0 -12px 30px rgba(0,0,0,.18)}.sticky-copy{color:#dceafa;font-weight:850;font-size:13px;line-height:1.2}.bonus-highlight{display:inline-flex;align-items:center;border-radius:999px;background:var(--yellow);color:var(--navy);font-weight:950;padding:4px 9px;margin-right:4px;box-shadow:0 0 0 2px rgba(255,255,255,.16),0 0 18px rgba(255,212,37,.35)}.sticky-cta .btn{flex:1;padding:12px;min-width:170px}
      @media(max-width:900px){.links,.actions{display:none}.burger{display:block}.nav{grid-template-columns:auto 1fr auto;padding:12px 14px}.logo{font-size:21px}.logo-flag{width:40px;height:40px}.hero{min-height:auto}.hero-in{grid-template-columns:1fr;padding:28px 14px 22px}.hero-inner{padding:28px 14px 22px}.lead{font-size:17px}.hero-card{padding:14px;border-radius:14px}.hero-card strong{font-size:20px}.content{padding:28px 14px}.grid,.reverse-grid,.split{grid-template-columns:1fr}.slot-grid,.mini-grid{grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}.pay-row{grid-template-columns:repeat(2,minmax(0,1fr))}.cta-band{grid-template-columns:1fr}.foot{grid-template-columns:1fr}.service-list{justify-content:flex-start}.sticky-cta{display:flex}.slot-head{display:block}.game-title-row{grid-template-columns:1fr;align-items:start}.section-cta{width:100%}.game-title-row h3{font-size:24px}.compact-list{grid-template-columns:1fr}.agebar{font-size:13px}.agebar-in{min-height:34px;padding:4px 14px}body{padding-bottom:82px}}
      @media(min-width:901px) and (max-width:1120px){.slot-grid,.mini-grid{grid-template-columns:repeat(4,minmax(0,1fr))}}
    </style>
  </head>
  <body>
    <amp-sidebar id="menu" layout="nodisplay" side="left">
      <button class="side-close" on="tap:menu.close">Schließen</button>
      <nav class="side-nav" aria-label="Mobile navigation">
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
      <p class="side-note">{site.copy.riskNote}</p>
    </amp-sidebar>
    <div class="sticky-shell">
      <div class="agebar"><div class="agebar-in"><span>Deutschland · unabhängiger Informationsratgeber</span><b>18+</b></div></div>
      <header class="top">
        <nav class="nav" aria-label="Main navigation">
          <a class="logo" href="/"><span class="logo-flag" aria-hidden="true"></span><span class="logo-text">Revolut Slots</span></a>
          <div class="links">{nav.map((item) => <a href={item.href}>{item.label}</a>)}</div>
          <div class="actions"><a class="btn btn-secondary" href="/registrierung/">Anmelden</a><a class="btn btn-primary" href={site.playPath} rel="nofollow">Bonus abholen</a></div>
          <button class="burger" on="tap:menu.open" aria-label="Menü öffnen">☰</button>
        </nav>
      </header>
    </div>
    <slot name="hero" />
    <main>
      <slot />
    </main>
    <nav class="internal-map" aria-label="Interne Verlinkung">
      <strong>Alle Bereiche im Revolut Slots Ratgeber</strong>
      <div class="internal-links">
        {internalLinks.map((item) => <a href={item.href}>{item.label}</a>)}
      </div>
    </nav>
    <footer>
      <div class="foot">
        <div><b>{site.mainKey}</b><p>{site.independentDisclosure} {site.copy.riskNote}</p></div>
        <div class="service-list">
          <a href="/verantwortungsvolles-spielen/">Verantwortung</a>
          <a href="/datenschutz/">Privacy Policy</a>
          <a href="/cookies/">Cookie Policy</a>
        </div>
      </div>
    </footer>
    {commercial && <div class="sticky-cta"><span class="sticky-copy"><span class="bonus-highlight">{site.copy.bonusHighlight}</span> im Revolut casino Check</span><a class="btn btn-primary" href={site.playPath} rel="nofollow">Bonus abholen</a></div>}
  </body>
</html>
