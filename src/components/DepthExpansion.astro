---
import site from "../../data/site.json";

const { page, kind = "commercial" } = Astro.props;

const profiles = {
  "/": {
    angle: "Startseite, Lobby und Brand-Hub",
    intents: ["Revolut Slots", "Bonus und App", "Revolut casino", "Zahlungen und Registrierung", "Deutschland-Check"],
    user: "ein Nutzer zuerst prüfen will, ob die Seite wie eine echte Casino-Lobby funktioniert",
    proof: "Spielbereiche, Zahlungsstrecke, Bonuskontext, App-Hinweis und Responsible-Gambling-Link",
    caution: "die Startseite nicht wie ein kopierter Review wirkt, sondern mehrere Suchintentionen sauber verteilt"
  },
  "/app/": {
    angle: "mobile Nutzung, APK und Login",
    intents: ["Revolut Slots App", "APK und Login", "Revolut casino", "mobile Website", "iOS und Android"],
    user: "ein Nutzer vom Smartphone aus entscheidet, ob Browser, App oder APK überhaupt sinnvoll sind",
    proof: "Geräteführung, Login-Sicherheit, App-Quelle, mobile CTA und klare Abgrenzung von Drittquellen",
    caution: "Download-Sprache nicht aggressiv wird und keine nicht belegte offizielle App behauptet"
  },
  "/bonus/": {
    angle: "Bonus, Promo Code und Freispiele",
    intents: ["Revolut Slots Bonus", "Promo Code", "Revolut casino", "Freispiele", "Wagering"],
    user: "ein Nutzer einen Bonus erst nach Umsatz, Spielbindung und Zahlungsart bewertet",
    proof: "Wagering, Auszahlungsgrenzen, Code-Regeln, Zahlungsqualifikation und 250 Freispiele als CTA-Kontext",
    caution: "der Bonusblock nicht wie ein übertriebener Claim aussieht"
  },
  "/registrierung/": {
    angle: "Konto, Anmeldung und KYC",
    intents: ["Revolut Slots Registrierung", "Konto und Login", "Revolut casino", "KYC", "Bonus-Opt-in"],
    user: "ein Nutzer persönliche Daten erst nach Domain-, Betreiber- und Sicherheitsprüfung eingibt",
    proof: "Registrierungsablauf, Login-Sicherheit, Altersprüfung, Bonus-Opt-in und spätere Zahlungsmethode",
    caution: "die Seite nicht als offizielles Login-Portal verstanden wird"
  },
  "/zahlungen/": {
    angle: "Einzahlung, Auszahlung und Payment-Icons",
    intents: ["Revolut Slots Zahlungen", "Einzahlung", "Revolut casino", "Auszahlung", "KYC und Limits"],
    user: "ein Nutzer vor der Einzahlung wissen will, welche Methode nur möglich und welche wirklich belegt ist",
    proof: "echte SVG-Icons aus dem Drive, weiße Kacheln, KYC, Limits und Bonusabgleich",
    caution: "keine Methode als bestätigt erscheint, wenn die Zielseite sie nicht belegt"
  },
  "/sportwetten/": {
    angle: "Sportwetten, Livewetten und Casino-Abgrenzung",
    intents: ["Revolut Slots Sportwetten", "Livewetten", "Revolut casino", "Wettbonus", "Quoten und Märkte"],
    user: "ein Nutzer Casino- und Betting-Regeln nicht vermischt",
    proof: "Märkte, Quoten, Live-Risiko, Wettbonus, Limits und klare Trennung von Slot-Bonus",
    caution: "Sportwetten nicht als beiläufiger Zusatz unter einem Casino-Keyword stehen"
  },
  "/verantwortungsvolles-spielen/": {
    angle: "Risiko, Limits und Schutz",
    intents: ["Revolut Slots", "Limits und Pausen", "Revolut casino", "Warnzeichen", "Selbstschutz"],
    user: "ein Nutzer die kommerziellen Seiten mit sichtbaren Grenzen und Pausenregeln einordnet",
    proof: "Budget, Zeit, Verlustlimit, Warnzeichen, Selbstschutz und lokale Hilfsstellen als spätere Ergänzung",
    caution: "Responsible Gambling nicht als dünner Footer-Link endet"
  },
  "/datenschutz/": {
    angle: "Datenschutz, Hosting und externe Ziele",
    intents: ["Revolut Slots", "Hosting und Logs", "Revolut casino", "Datenminimierung", "externe Links"],
    user: "ein Nutzer versteht, wo keine Konto-, Banking- oder Casino-Daten eingegeben werden",
    proof: "Cloudflare-Auslieferung, technische Logs, externe Links, Tracking-Status und Datenminimierung",
    caution: "Privacy Policy nicht wie ein leerer Standardtext wirkt"
  },
  "/cookies/": {
    angle: "Cookies, Consent und Affiliate-Weiterleitung",
    intents: ["Revolut Slots", "Consent", "Revolut casino", "Affiliate-Link", "Tracking-Prüfung"],
    user: "ein Nutzer erkennt, welche Tracking-Funktionen noch nicht aktiv sind und später freigegeben werden müssen",
    proof: "technische Cookies, Analytics-Gate, Affiliate-Pfad, externe Cookie-Regeln und Update-Pflicht",
    caution: "Cookie-Texte nicht ungeprüft von Brand zu Brand kopiert werden"
  }
};

const profile = profiles[page.path] || profiles["/"];
const commercialIntro = kind === "commercial"
  ? "Die kommerzielle Seite muss schnell zur Aktion führen, aber sie darf den Prüfcharakter nicht verlieren."
  : "Die Service-Seite stützt die kommerziellen Bereiche und bleibt bewusst ohne aggressive Conversion-Sprache.";
const h2 = (text, index) => {
  const intent = profile.intents[(index === 0 ? 1 : index) % profile.intents.length];
  return `${intent}: ${text}`;
};
const h3 = (text, index) => {
  const intent = profile.intents[(index + 1) % profile.intents.length];
  return index % 2 === 0 ? `${text} für ${intent}` : text;
};

const blocks = [
  {
    heading: `${profile.angle} als eigenständiger Seitenblock`,
    focus: "Struktur",
    paragraphs: [
      `${commercialIntro} Für ${page.h1} bedeutet das: Der Text arbeitet mit dem Main Key ${site.mainKey}, nimmt ${site.secondaryKey} als zweiten Suchraum auf und erklärt Deutschland sowie DE nicht nur in einer Zeile, sondern in mehreren konkreten Prüfpunkten. Dadurch entsteht ein längerer, ruhigerer Lesefluss, der sich stärker an echten Brand-Seiten orientiert.`,
      `Wichtig ist dabei die Reihenfolge. Erst kommt der kompakte Hero mit CTA, Tabelle und sichtbarem 18+ Kontext, danach folgen Spiel- oder Serviceelemente, anschließend Tabellen, Listen und tiefere Abschnitte. So sieht ${page.h1} nicht wie ein einzelner SEO-Artikel aus, sondern wie eine Seite, auf der ${profile.user}.`,
      `Die Inhalte werden absichtlich nicht aus einem allgemeinen Casino-Text gespiegelt. Jedes Segment greift ${profile.proof} auf und verbindet diese Punkte mit interner Verlinkung zur Hauptseite. Das hält die Seite für Deutschland nachvollziehbar und gibt künftigen Brand-Generierungen eine Struktur, die nicht an einem einzigen starren Absatzmuster hängt.`
    ],
    checks: ["Hero zuerst", "Tabelle sichtbar", "Interner Link zur Hauptseite", "18+ Kontext", "Keine offiziellen Revolut-Claims"]
  },
  {
    heading: "Texttiefe, Untergliederung und Reverse-Abgleich",
    focus: "Inhalt",
    paragraphs: [
      `Ein starker Reverse-Abgleich misst nicht nur Wörter. Er prüft, ob Abschnitte, Unterabschnitte, Listen, Tabellen und CTA-Zonen ähnlich dicht sind wie die Vergleichsseiten. Deshalb bekommt ${page.h1} zusätzliche Texttiefe, ohne in Copy-Paste zu kippen: Die Form bleibt wiedererkennbar, aber die Argumente werden auf ${profile.angle} zugeschnitten.`,
      `Die Zwischenüberschriften tragen regelmäßig ${site.mainKey} oder ${site.secondaryKey}, weil die Brand- und Casino-Intention im Text sichtbar bleiben muss. Gleichzeitig werden die Begriffe nicht mechanisch in jeden Satz gedrückt. Der Inhalt erklärt lieber, warum ein Nutzer in Deutschland eine Information braucht, welche Quelle später fehlt und welche Entscheidung vor einem Klick auf den CTA noch offen ist.`,
      `So wird die Seite länger, aber nicht schwerfällig. Kurze Absätze halten den mobilen Scan möglich, während H2 und H3 die Tiefe liefern. Tabellen bleiben für Fakten reserviert, Listen für Prüfschritte, und erklärende Absätze für Kontext. Genau diese Mischung war in den Reverse-Beispielen wichtiger als ein einzelner riesiger Textblock.`
    ],
    checks: ["Mehrere H2", "Mehrere H3", "Listen ohne doppelte Marker", "Tabellen mit Prüflogik", "Keine Systemlabels im Frontend"]
  },
  {
    heading: "Visuelle Varianz ohne Footprint-Blöcke",
    focus: "Visual",
    paragraphs: [
      `Visuelle Qualität entsteht nicht durch viele weiße Standardkarten. Für ${page.h1} werden die funktionalen Elemente daher klarer getrennt: Slot-Karten bleiben quadratisch, Payment-Logos stehen auf weißen Flächen, Service-Links werden im Footer als dezente Textnavigation geführt und die mobilen CTAs werden nicht mit weiteren Menüs überladen.`,
      `Die Slotbilder stammen aus der extrahierten 200x200-Datenbank. Beim Hover erscheint eine Play-Ebene, und der Link führt auf ${site.playPath}, damit alle Spielkarten denselben kontrollierten Weiterleitungsweg nutzen. Das macht die Seite für künftige Brands leichter rotierbar: Reihenfolge, Kategorie und Auswahl können wechseln, ohne dass das Layout bricht.`,
      `Auch der Header folgt diesem Prinzip. Das runde Deutschland-Signal ersetzt das generische Buchstaben-Icon, ${site.mainKey} bleibt in einer Zeile, der Burger sitzt nur oben rechts und die mobile untere Leiste bleibt eine einzige CTA-Zone. Dadurch verschwindet der Eindruck eines zusammengeklebten Templates.`
    ],
    checks: ["Rundes DE-Signal", "Sticky Header", "Nur eine mobile CTA unten", "Slot-Hover mit Play", "Payment-SVG statt Textnamen"]
  },
  {
    heading: "Qualitätssicherung für spätere Brand-Generierung",
    focus: "Audit",
    paragraphs: [
      `Damit ${page.h1} nicht wieder in alte Fehler zurückfällt, muss der Build automatisch gegen sichtbare Footprints prüfen. Interne Redaktionsnotizen, technische Blocknamen und unfertige Freigabehinweise dürfen nicht im Frontend auftauchen. Wenn sie doch im HTML landen, muss der Audit fehlschlagen.`,
      `Dasselbe gilt für Umfang und Struktur. Unter 10.000 Zeichen wäre die Seite für diesen Brand zu dünn, besonders weil ${site.secondaryKey}, App, Bonus, Zahlungen und Sportwetten jeweils eigene Suchintentionen tragen. Die Prüfung muss deshalb Zeichenlänge, Tabellen, Listen, lokale Slot-Bilder, echte Payment-Assets, interne Links und Headline-Abdeckung zusammen auswerten.`,
      `Diese Regeln reduzieren dein manuelles Eingreifen. Du gibst künftig Brand, GEO, Hauptkey, zweiten Key, Seitenliste und freigegebene Assets vor. Das Template erzeugt daraus eine Variante, prüft sich selbst und zeigt nur noch die Stellen, an denen echte Quellen oder manuelle Freigabe fehlen. Genau dort bleibt menschliche Kontrolle sinnvoll.`
    ],
    checks: ["10.000+ Zeichen", "Key-Abdeckung in Untertiteln", "Assets lokal", "CTA-Pfad einheitlich", "Build bricht bei Footprints"]
  },
  {
    heading: "Quellenfreigabe und manuelle Kontrolle",
    focus: "Freigabe",
    paragraphs: [
      `Der letzte Schritt ist nicht noch mehr Text, sondern eine klare Freigabelogik. Für ${page.h1} bleiben Bonuswerte, Lizenzangaben, Zahlungsfreigaben, App-Downloads und Sportwettenmärkte so lange vorsichtig formuliert, bis eine echte Quelle vorliegt. Dadurch kann die Seite ausführlich sein, ohne dem Nutzer Sicherheit vorzutäuschen.`,
      `Die manuelle Arbeit verschiebt sich damit auf wenige Entscheidungen: Welche Assets sind freigegeben, welcher Affiliate-Link ist aktiv, welche Bonusbedingungen sind belegt und welche GEO-Regel gilt wirklich. Alles andere übernimmt die Struktur. ${site.mainKey} und ${site.secondaryKey} bleiben im Text präsent, aber die Aussagen werden an Quelle, Risiko und Nutzerabsicht gebunden.`,
      `Für künftige Marken kann derselbe Mechanismus andere Spielauswahl, andere Payment-Reihenfolge, andere Hero-Details und andere Unterseiten gewichten. Genau diese kontrollierte Variation ist wichtiger als zufälliges Umformulieren. Sie sorgt dafür, dass jede neue Seite eigenständig wirkt und trotzdem nach festen Qualitätsgrenzen gebaut wird.`
    ],
    checks: ["Bonuswerte erst nach Quelle", "Affiliate-Link zentral", "GEO-Regel sichtbar", "Assets aus Archiv", "Manuelle Freigabe gezielt"]
  }
];
---

<div class="depth-expansion">
  {blocks.map((block, index) => (
    <article class="depth-block">
      <h2>{h2(block.heading, index)}</h2>
      {block.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      <h3>{h3(`${block.focus} als Prüfebene`, index)}</h3>
      <ul class="check-list compact-list">
        {block.checks.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  ))}
</div>
