---
import BrandLayout from "../layouts/BrandLayout.astro";
import FactTable from "./FactTable.astro";
import DepthExpansion from "./DepthExpansion.astro";
import site from "../../data/site.json";

const { page } = Astro.props;
const keyedHeading = (heading, index) => {
  if (index % 2 !== 0) return heading;
  const key = index % 2 === 0 ? site.mainKey : site.secondaryKey;
  return heading.includes(site.mainKey) || heading.includes(site.secondaryKey) ? heading : `${key}: ${heading}`;
};
const keyedSubheading = (heading, sectionIndex, subsectionIndex) => {
  if ((sectionIndex + subsectionIndex) % 3 !== 1) return heading;
  const key = sectionIndex % 2 === 0 ? site.secondaryKey : site.mainKey;
  return heading.includes(site.mainKey) || heading.includes(site.secondaryKey) ? heading : `${key} ${heading}`;
};
---

<BrandLayout title={page.title} description={page.description} path={page.path} commercial={false}>
  <section class="hero" slot="hero">
    <div class="hero-in">
      <div>
        <p class="eyebrow">{page.eyebrow}</p>
        <h1>{page.h1}</h1>
        <p class="lead">{page.lead}</p>
        <div class="cta-row">
          <a class="btn btn-secondary" href="/">Zur Hauptseite</a>
          <a class="btn btn-primary" href="/verantwortungsvolles-spielen/">18+ Hinweise</a>
        </div>
      </div>
      <div class="hero-card">
        <strong>Service Check</strong>
        <table class="hero-table">
          <tbody>
            <tr><th scope="row">Geo</th><td>DE</td></tr>
            <tr><th scope="row">Seitentyp</th><td>Ratgeber</td></tr>
            <tr><th scope="row">Suchbezug</th><td>Revolut Slots</td></tr>
            <tr><th scope="row">Offiziell</th><td>Nein</td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <div class="terms">Service-Seite · keine offizielle Revolut Website · 18+</div>
  </section>

  <section class="content reverse-page">
    <div class="disclosure">{site.independentDisclosure}</div>
    <p>Die <a href="/">Revolut Slots Hauptseite</a> verlinkt diese Service-Seite als Pflichtbereich. {page.homeContext}</p>
    <FactTable caption={page.factCaption} rows={page.factRows} />

    {page.sections.map((section) => (
      <article class="reverse-block">
        <h2>{keyedHeading(section.heading, page.sections.indexOf(section))}</h2>
        {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        {section.subsections?.map((subsection) => (
          <div class="subsection">
            <h3>{keyedSubheading(subsection.heading, page.sections.indexOf(section), section.subsections.indexOf(subsection))}</h3>
            {subsection.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
            {subsection.list && (
              <ul class="check-list compact-list">
                {subsection.list.map((item) => <li>{item}</li>)}
              </ul>
            )}
          </div>
        ))}
        {section.list && (
          <ul class="check-list">
            {section.list.map((item) => <li>{item}</li>)}
          </ul>
        )}
      </article>
    ))}
    <DepthExpansion page={page} kind="service" />
  </section>
</BrandLayout>
