---
import site from "../../data/site.json";
import HeroBackground from "./HeroBackground.astro";

const {
  eyebrow = "Casino & Slots Deutschland",
  title = site.mainKey,
  lead,
  cta = "Bonus abholen",
  heroRows = [
    ["Suchfokus", site.mainKey],
    ["Casino-Intent", site.secondaryKey],
    ["Slot-Intent", "Spielauswahl und Online-Slots"],
    ["Zahlungs-Intent", "Revolut als Bank-Zahlungsmittel prüfen"],
    ["Deutschland", "DE, 18+ und Quellenprüfung"]
  ]
} = Astro.props;
const expandedLead = `${lead} Direkt im ersten View werden Slot-Suche, ${site.secondaryKey}, Revolut als möglicher Bank-Zahlungsweg und Deutschland getrennt erklärt, damit der Nutzer sofort erkennt, welche Intention die Seite beantwortet.`;
---

<section class="hero">
  <HeroBackground />
  <div class="hero-in">
    <div>
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="lead">{expandedLead}</p>
      <div class="cta-row">
        <a class="btn btn-primary" href={site.playPath} rel="nofollow">{cta}</a>
        <a class="btn btn-secondary" href="/">Zur Hauptseite</a>
      </div>
    </div>
    <div class="hero-card">
      <strong>Suchintention im Überblick</strong>
      <table class="hero-table">
        <tbody>
          {heroRows.map((row) => <tr><th scope="row">{row[0]}</th><td>{row[1]}</td></tr>)}
        </tbody>
      </table>
    </div>
  </div>
  <div class="terms">Allgemeine Geschäftsbedingungen prüfen. Keine offizielle Revolut Website.</div>
</section>
